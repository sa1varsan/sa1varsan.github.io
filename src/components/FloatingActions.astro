---
interface Props {
	showBack?: boolean;
	backHref?: string;
	backLabel?: string;
}

const {
	showBack = false,
	backHref = `${import.meta.env.BASE_URL}blog/`,
	backLabel = 'Back',
} = Astro.props;
---

<div class="floating-actions">
	{showBack && (
		<a class="floating-action" href={backHref} aria-label={backLabel} title={backLabel}>
			<svg class="floating-action__icon" viewBox="0 0 24 24" aria-hidden="true">
				<path
					d="M15.75 5.25 9 12l6.75 6.75"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="1.9"
				/>
			</svg>
			<span class="sr-only">{backLabel}</span>
		</a>
	)}
	<button
		class="floating-action floating-action--theme"
		type="button"
		data-theme-toggle
		aria-label="主题切换"
		title="主题切换"
	>
		<span class="floating-action__icon" data-theme-icon aria-hidden="true"></span>
		<span class="sr-only" data-theme-label>跟随系统</span>
	</button>
</div>

<script is:inline>
	const THEME_KEY = 'study-notes-theme';
	const THEME_OPTIONS = [
		{
			value: 'system',
			label: '跟随系统',
			icon:
				'<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4.75" y="5.5" width="14.5" height="10.5" rx="2" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M9 19.25h6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.6"/></svg>',
		},
		{
			value: 'light',
			label: '白天',
			icon:
				'<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M12 2.75v2.1M12 19.15v2.1M21.25 12h-2.1M4.85 12h-2.1M18.54 5.46l-1.49 1.49M6.95 17.05l-1.49 1.49M18.54 18.54l-1.49-1.49M6.95 6.95 5.46 5.46" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.6"/></svg>',
		},
		{
			value: 'dark',
			label: '夜间',
			icon:
				'<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.2 15.46A6.55 6.55 0 0 1 8.54 6.8a7.45 7.45 0 1 0 8.66 8.66Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.7"/></svg>',
		},
	];

	const root = document.documentElement;
	const toggle = document.querySelector('[data-theme-toggle]');
	const label = document.querySelector('[data-theme-label]');
	const icon = document.querySelector('[data-theme-icon]');
	const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

	const getStoredMode = () => {
		try {
			const stored = localStorage.getItem(THEME_KEY);
			return THEME_OPTIONS.some((option) => option.value === stored) ? stored : 'system';
		} catch {
			return 'system';
		}
	};

	const resolveTheme = (mode) =>
		mode === 'system' ? (mediaQuery.matches ? 'dark' : 'light') : mode;

	const applyTheme = (mode, persist = true) => {
		root.dataset.theme = mode;
		root.style.colorScheme = resolveTheme(mode);
		const option = THEME_OPTIONS.find((item) => item.value === mode) ?? THEME_OPTIONS[0];
		if (label) label.textContent = option.label;
		if (icon) icon.innerHTML = option.icon;
		if (toggle) {
			toggle.setAttribute('aria-label', `主题切换，当前为${option.label}`);
			toggle.setAttribute('title', `主题：${option.label}`);
		}
		if (persist) {
			try {
				localStorage.setItem(THEME_KEY, mode);
			} catch {
				// Ignore storage failures.
			}
		}
	};

	if (toggle) {
		let currentMode = getStoredMode();
		applyTheme(currentMode, false);

		toggle.addEventListener('click', () => {
			const index = THEME_OPTIONS.findIndex((option) => option.value === currentMode);
			currentMode = THEME_OPTIONS[(index + 1) % THEME_OPTIONS.length]?.value ?? 'system';
			applyTheme(currentMode, true);
		});

		mediaQuery.addEventListener('change', () => {
			if (currentMode === 'system') {
				applyTheme('system', false);
			}
		});
	}
</script>

<style>
	.floating-actions {
		position: fixed;
		right: 1.5rem;
		bottom: 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.65rem;
		z-index: 40;
	}

	.floating-action {
		width: 2.85rem;
		height: 2.85rem;
		padding: 0;
		border-radius: 999px;
		border: 1px solid rgb(var(--gray-light));
		background: rgba(var(--surface-rgb), 0.92);
		backdrop-filter: blur(14px);
		box-shadow: 0 12px 26px rgba(0, 0, 0, 0.14);
		color: rgb(var(--black));
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			background 0.18s ease,
			border-color 0.18s ease;
	}

	button.floating-action {
		font: inherit;
		cursor: pointer;
	}

	.floating-action:hover {
		transform: translateY(-1px);
		background: rgba(var(--surface-rgb), 0.98);
		box-shadow: 0 14px 30px rgba(0, 0, 0, 0.18);
		border-color: rgba(var(--accent-rgb), 0.28);
	}

	.floating-action__icon {
		display: inline-flex;
		width: 1.12rem;
		height: 1.12rem;
		align-items: center;
		justify-content: center;
	}

	.floating-action__icon :global(svg) {
		width: 100%;
		height: 100%;
	}

	@media (max-width: 720px) {
		.floating-actions {
			right: 1rem;
			bottom: 1rem;
			gap: 0.5rem;
		}

		.floating-action {
			width: 2.65rem;
			height: 2.65rem;
		}

		.floating-action__icon {
			width: 1rem;
			height: 1rem;
		}
	}
</style>
