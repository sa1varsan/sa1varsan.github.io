---
import { loadNeteasePlaylist } from '../utils/neteasePlaylist';

const { playlistId } = Astro.props as { playlistId: string };

const playerId = `netease-player-${playlistId}`;
const playlist = await loadNeteasePlaylist(playlistId);

playlist.tracks = [...playlist.tracks].reverse();

const initialTrack = playlist.tracks[0] ?? null;
const initialCoverImage = initialTrack?.coverImage || playlist.coverImage;
const playerPayload = JSON.stringify(playlist);
---

<aside class="netease-player" id={playerId} data-playlist={playerPayload}>
	<div class="netease-player__surface">
		<div class="netease-player__cover" aria-hidden="true">
			<img data-cover-image src={initialCoverImage} alt={`${initialTrack?.title ?? playlist.title} cover`} loading="lazy" hidden={!initialCoverImage} />
			<span class="netease-player__cover-fallback" data-cover-fallback aria-hidden="true" hidden={Boolean(initialCoverImage)}>N</span>
		</div>

		<div class="netease-player__body">
			<p class="netease-player__track-title" data-current-title>
				{initialTrack?.title ?? 'Playlist unavailable'}
			</p>
			<p class="netease-player__meta" data-player-meta>
				{playlist.tracks.length > 0 ? `1 / ${playlist.tracks.length}` : 'Unable to load playlist data'}
			</p>

			<div class="netease-player__progress-row">
				<span class="netease-player__time" data-current-time>0:00</span>
				<input class="netease-player__seek" type="range" min="0" max="100" step="0.1" value="0" data-seek />
				<span class="netease-player__time" data-duration>0:00</span>
			</div>

			<div class="netease-player__controls">
				<button class="netease-player__control netease-player__control--circle" type="button" data-prev aria-label="上一首" disabled={playlist.tracks.length === 0}>
					<svg class="netease-player__icon netease-player__icon--fill" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M18 6v12h-2V6h2Z" />
						<path d="M14 18 5 12l9-6v12Z" />
					</svg>
					<span class="sr-only">上一首</span>
				</button>
				<button
					class="netease-player__control netease-player__control--circle netease-player__control--primary"
					type="button"
					data-play-toggle
					data-state="paused"
					aria-label="播放"
					disabled={playlist.tracks.length === 0}
				>
					<svg class="netease-player__icon netease-player__icon--fill netease-player__icon-play" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M8 6.5v11l9-5.5-9-5.5Z" />
					</svg>
					<svg class="netease-player__icon netease-player__icon--fill netease-player__icon-pause" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M8 6h3v12H8z" />
						<path d="M13 6h3v12h-3z" />
					</svg>
					<span class="sr-only" data-play-label>播放</span>
				</button>
				<button class="netease-player__control netease-player__control--circle" type="button" data-next aria-label="下一首" disabled={playlist.tracks.length === 0}>
					<svg class="netease-player__icon netease-player__icon--fill" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M6 6v12h2V6H6Z" />
						<path d="m10 18 9-6-9-6v12Z" />
					</svg>
					<span class="sr-only">下一首</span>
				</button>
				<button
					class="netease-player__control netease-player__control--circle netease-player__mode"
					type="button"
					data-mode
					aria-label="顺序播放"
					disabled={playlist.tracks.length === 0}
				>
					<svg class="netease-player__icon netease-player__icon--stroke netease-player__mode-icon netease-player__mode-icon--sequence" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M6 7h9" />
						<path d="M6 17h9" />
						<path d="m13 5 3 2-3 2" />
						<path d="m13 15 3 2-3 2" />
					</svg>
					<svg class="netease-player__icon netease-player__icon--stroke netease-player__mode-icon netease-player__mode-icon--loop" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M7 7h8a3 3 0 0 1 3 3v1" />
						<path d="m15 5 3 3-3 3" />
						<path d="M17 17H9a3 3 0 0 1-3-3v-1" />
						<path d="m9 19-3-3 3-3" />
						<path d="M12 9.4v5.2" />
					</svg>
					<svg class="netease-player__icon netease-player__icon--stroke netease-player__mode-icon netease-player__mode-icon--random" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M4 7h3.4c1.7 0 2.8.6 4 2l1.2 1.4" />
						<path d="M4 17h3.4c1.7 0 2.8-.6 4-2L20 7" />
						<path d="M16 5h4v4" />
						<path d="M16 19h4v-4" />
					</svg>
					<span class="sr-only" data-mode-label>顺序播放</span>
				</button>
				<button
					class="netease-player__control netease-player__control--circle netease-player__queue-toggle--inline"
					type="button"
					data-queue-toggle
					aria-label="列表"
					aria-expanded="false"
					disabled={playlist.tracks.length === 0}
				>
					<svg class="netease-player__icon netease-player__icon--stroke" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M8 7h12" />
						<path d="M8 12h12" />
						<path d="M8 17h12" />
						<circle cx="4" cy="7" r="1" fill="currentColor" stroke="none" />
						<circle cx="4" cy="12" r="1" fill="currentColor" stroke="none" />
						<circle cx="4" cy="17" r="1" fill="currentColor" stroke="none" />
					</svg>
					<span class="sr-only">列表</span>
				</button>
			</div>
		</div>
	</div>

	<div class="netease-player__queue" data-queue hidden>
		<ol class="netease-player__queue-list">
			{
				playlist.tracks.map((track, index) => (
					<li>
						<button class="netease-player__queue-item" type="button" data-track-index={index}>
							<span class="netease-player__queue-index">{index + 1}</span>
							<span class="netease-player__queue-copy">
								<span class="netease-player__queue-title" data-marquee>
									<span class="netease-player__queue-title-text" data-marquee-text>{track.title}</span>
								</span>
								<span class="netease-player__queue-artist">{track.artists}</span>
							</span>
						</button>
					</li>
				))
			}
		</ol>
	</div>

	<audio data-audio preload="none" src={initialTrack?.audioSrc}></audio>
</aside>

<script is:inline define:vars={{ playerId }}>
	const playerRoot = document.getElementById(playerId);

	if (playerRoot) {
		const playlist = JSON.parse(playerRoot.getAttribute('data-playlist') ?? '{"tracks": []}');
		const tracks = Array.isArray(playlist.tracks) ? playlist.tracks : [];
		const audio = playerRoot.querySelector('[data-audio]');
		const coverImage = playerRoot.querySelector('[data-cover-image]');
		const coverFallback = playerRoot.querySelector('[data-cover-fallback]');
		const title = playerRoot.querySelector('[data-current-title]');
		const meta = playerRoot.querySelector('[data-player-meta]');
		const currentTimeLabel = playerRoot.querySelector('[data-current-time]');
		const durationLabel = playerRoot.querySelector('[data-duration]');
		const seek = playerRoot.querySelector('[data-seek]');
		const playToggle = playerRoot.querySelector('[data-play-toggle]');
		const playLabel = playerRoot.querySelector('[data-play-label]');
		const prevButton = playerRoot.querySelector('[data-prev]');
		const nextButton = playerRoot.querySelector('[data-next]');
		const modeButton = playerRoot.querySelector('[data-mode]');
		const modeLabel = playerRoot.querySelector('[data-mode-label]');
		const queueToggle = playerRoot.querySelector('[data-queue-toggle]');
		const queue = playerRoot.querySelector('[data-queue]');
		const queueButtons = Array.from(playerRoot.querySelectorAll('[data-track-index]'));
		const marqueeRoots = Array.from(playerRoot.querySelectorAll('[data-marquee]'));

		const modes = [
			{ key: 'sequence', label: '顺序播放' },
			{ key: 'loop', label: '单曲循环' },
			{ key: 'random', label: '随机播放' },
		];

		let currentIndex = tracks.length > 0 ? 0 : -1;
		let modeIndex = 0;
		let seeking = false;
		let history = currentIndex >= 0 ? [currentIndex] : [];
		let historyPointer = history.length - 1;

		const getMode = () => modes[modeIndex];

		const formatTime = (value) => {
			if (!Number.isFinite(value) || value < 0) {
				return '0:00';
			}

			const minutes = Math.floor(value / 60);
			const seconds = Math.floor(value % 60)
				.toString()
				.padStart(2, '0');

			return `${minutes}:${seconds}`;
		};

		const setMeta = (text) => {
			if (meta) {
				meta.textContent = text;
			}
		};

		const syncPlaybackUI = () => {
			const playing = Boolean(audio && !audio.paused && !audio.ended);

			if (playToggle) {
				playToggle.dataset.state = playing ? 'playing' : 'paused';
				playToggle.setAttribute('aria-label', playing ? '暂停' : '播放');
			}

			if (playLabel) {
				playLabel.textContent = playing ? '暂停' : '播放';
			}
		};

		const syncModeUI = () => {
			const mode = getMode();

			if (modeButton) {
				modeButton.dataset.mode = mode.key;
				modeButton.setAttribute('aria-label', mode.label);
			}

			if (modeLabel) {
				modeLabel.textContent = mode.label;
			}

			if (audio) {
				audio.loop = mode.key === 'loop';
			}
		};

		const syncTrackUI = () => {
			const track = tracks[currentIndex];
			const mode = getMode();

			if (title) {
				title.textContent = track?.title ?? 'Playlist unavailable';
			}

			if (coverImage) {
				const nextCover = track?.coverImage || playlist.coverImage || '';
				if (nextCover) {
					coverImage.setAttribute('src', nextCover);
					coverImage.setAttribute('alt', `${track?.title ?? playlist.title} cover`);
					coverImage.removeAttribute('hidden');
					coverFallback?.setAttribute('hidden', '');
				} else {
					coverImage.setAttribute('hidden', '');
					coverFallback?.removeAttribute('hidden');
				}
			}

			queueButtons.forEach((button) => {
				const index = Number(button.getAttribute('data-track-index'));
				button.classList.toggle('is-active', index === currentIndex);
			});

			if (track) {
				setMeta(`${currentIndex + 1} / ${tracks.length} · ${mode.label}`);
			} else {
				setMeta('Unable to load playlist data');
			}
		};

		const updateProgress = () => {
			if (!audio || !seek) {
				return;
			}

			const duration = Number.isFinite(audio.duration) ? audio.duration : 0;
			const currentTime = Number.isFinite(audio.currentTime) ? audio.currentTime : 0;

			if (!seeking) {
				seek.value = duration > 0 ? String((currentTime / duration) * 100) : '0';
			}

			if (currentTimeLabel) {
				currentTimeLabel.textContent = formatTime(currentTime);
			}

			if (durationLabel) {
				durationLabel.textContent = formatTime(duration);
			}
		};

		const syncQueueTitleMarquees = () => {
			marqueeRoots.forEach((root) => {
				const text = root.querySelector('[data-marquee-text]');
				if (!text) {
					return;
				}

				root.classList.remove('is-overflowing');
				root.style.removeProperty('--marquee-distance');

				if (root.clientWidth <= 0 || text.scrollWidth <= root.clientWidth + 1) {
					return;
				}

				root.style.setProperty('--marquee-distance', `${text.scrollWidth - root.clientWidth}px`);
				root.classList.add('is-overflowing');
			});
		};

		const chooseRandomIndex = () => {
			if (tracks.length <= 1) {
				return currentIndex;
			}

			let nextIndex = currentIndex;

			while (nextIndex === currentIndex) {
				nextIndex = Math.floor(Math.random() * tracks.length);
			}

			return nextIndex;
		};

		const getSequentialIndex = (direction) => {
			if (tracks.length === 0) {
				return -1;
			}

			if (direction === 'previous') {
				return currentIndex > 0 ? currentIndex - 1 : 0;
			}

			return currentIndex < tracks.length - 1 ? currentIndex + 1 : 0;
		};

		const pushHistory = (index) => {
			if (history[historyPointer] === index) {
				return;
			}

			history = history.slice(0, historyPointer + 1);
			history.push(index);
			historyPointer = history.length - 1;
		};

		const setTrack = (index, options = {}) => {
			if (!audio || index < 0 || index >= tracks.length) {
				return;
			}

			const { autoplay = false, pushToHistory = true } = options;
			const track = tracks[index];

			currentIndex = index;
			audio.src = track.audioSrc;
			audio.load();

			if (pushToHistory) {
				pushHistory(index);
			}

			if (seek) {
				seek.value = '0';
			}

			if (currentTimeLabel) {
				currentTimeLabel.textContent = '0:00';
			}

			if (durationLabel) {
				durationLabel.textContent = '0:00';
			}

			syncTrackUI();
			syncPlaybackUI();

			if (autoplay) {
				audio.play().then(syncPlaybackUI).catch(syncPlaybackUI);
			}
		};

		const goToPrevious = () => {
			if (!audio || tracks.length === 0) {
				return;
			}

			const shouldPlay = !audio.paused;
			const mode = getMode();

			if (mode.key === 'random' && historyPointer > 0) {
				historyPointer -= 1;
				setTrack(history[historyPointer], { autoplay: shouldPlay, pushToHistory: false });
				return;
			}

			const previousIndex = getSequentialIndex('previous');

			if (previousIndex >= 0) {
				setTrack(previousIndex, { autoplay: shouldPlay });
			}
		};

		const goToNext = (autoplay = false) => {
			if (!audio || tracks.length === 0) {
				return;
			}

			const mode = getMode();

			if (mode.key === 'random' && historyPointer < history.length - 1) {
				historyPointer += 1;
				setTrack(history[historyPointer], { autoplay, pushToHistory: false });
				return;
			}

			const nextIndex = mode.key === 'random' ? chooseRandomIndex() : getSequentialIndex('next');

			if (nextIndex === -1) {
				syncPlaybackUI();
				return;
			}

			setTrack(nextIndex, { autoplay });
		};

		const togglePlayback = () => {
			if (!audio || currentIndex < 0) {
				return;
			}

			if (audio.paused) {
				audio.play().then(syncPlaybackUI).catch(syncPlaybackUI);
				return;
			}

			audio.pause();
			syncPlaybackUI();
		};

		syncModeUI();
		syncTrackUI();
		syncQueueTitleMarquees();
		updateProgress();
		syncPlaybackUI();

		playToggle?.addEventListener('click', togglePlayback);
		prevButton?.addEventListener('click', goToPrevious);
		nextButton?.addEventListener('click', () => goToNext(!audio?.paused));

		modeButton?.addEventListener('click', () => {
			modeIndex = (modeIndex + 1) % modes.length;
			syncModeUI();
			syncTrackUI();
		});

		queueToggle?.addEventListener('click', () => {
			if (!queue) {
				return;
			}

			const open = queue.hasAttribute('hidden');

			if (open) {
				queue.removeAttribute('hidden');
				queueToggle.setAttribute('aria-expanded', 'true');
				requestAnimationFrame(syncQueueTitleMarquees);
			} else {
				queue.setAttribute('hidden', '');
				queueToggle.setAttribute('aria-expanded', 'false');
			}
		});

		queueButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const index = Number(button.getAttribute('data-track-index'));
				setTrack(index, { autoplay: true });
			});
		});

		seek?.addEventListener('input', () => {
			if (!audio || !seek) {
				return;
			}

			seeking = true;
			const duration = Number.isFinite(audio.duration) ? audio.duration : 0;
			const nextTime = duration > 0 ? (Number(seek.value) / 100) * duration : 0;

			if (currentTimeLabel) {
				currentTimeLabel.textContent = formatTime(nextTime);
			}
		});

		seek?.addEventListener('change', () => {
			if (!audio || !seek) {
				return;
			}

			const duration = Number.isFinite(audio.duration) ? audio.duration : 0;
			audio.currentTime = duration > 0 ? (Number(seek.value) / 100) * duration : 0;
			seeking = false;
			updateProgress();
		});

		audio?.addEventListener('loadedmetadata', updateProgress);
		audio?.addEventListener('timeupdate', updateProgress);
		audio?.addEventListener('play', syncPlaybackUI);
		audio?.addEventListener('pause', syncPlaybackUI);
		window.addEventListener('resize', syncQueueTitleMarquees);

		audio?.addEventListener('ended', () => {
			const mode = getMode();

			if (mode.key === 'loop') {
				audio.currentTime = 0;
				audio.play().catch(syncPlaybackUI);
				return;
			}

			goToNext(true);
		});

		audio?.addEventListener('error', () => {
			setMeta('Track unavailable, trying the next one');
			goToNext(true);
		});
	}
</script>

<style>
	.netease-player {
		position: fixed;
		left: 1rem;
		bottom: 1rem;
		width: min(360px, calc(100vw - 6.5rem));
		z-index: 35;
	}

	.netease-player__surface,
	.netease-player__queue {
		border: 1px solid rgba(var(--gray-light), 0.92);
		background: rgba(var(--surface-rgb), 0.9);
		backdrop-filter: blur(16px);
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.18);
		border-radius: 16px;
	}

	.netease-player__surface {
		display: grid;
		grid-template-columns: 88px minmax(0, 1fr);
		align-items: stretch;
		gap: 0.72rem;
		padding: 0.75rem;
	}

	.netease-player__cover {
		position: relative;
		width: auto;
		aspect-ratio: 1 / 1;
		height: auto;
		align-self: center;
		border-radius: 12px;
		background: rgba(var(--gray-light), 0.45);
		overflow: hidden;
	}

	.netease-player__cover img,
	.netease-player__cover-fallback {
		display: block;
		width: 100%;
		height: 100%;
	}

	.netease-player__cover img {
		object-fit: cover;
		border-radius: 0;
	}

	.netease-player__cover-fallback {
		display: grid;
		place-items: center;
		font-size: 1.1rem;
		font-weight: 700;
		color: rgb(var(--gray-dark));
	}

	.netease-player__body {
		min-width: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.36rem;
	}

	.netease-player__control {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(var(--gray-light), 0.92);
		background: rgba(var(--surface-rgb), 0.6);
		color: rgb(var(--black));
		font: inherit;
		font-size: 0.78rem;
		font-weight: 700;
		cursor: pointer;
		transition:
			background 0.18s ease,
			border-color 0.18s ease,
			transform 0.18s ease,
			color 0.18s ease;
	}

	.netease-player__control:disabled {
		cursor: default;
		opacity: 0.5;
	}

	.netease-player__control:not(:disabled):hover,
	.netease-player__queue-item:hover {
		transform: translateY(-1px);
	}

	.netease-player__queue-toggle--inline {
		margin-left: auto;
	}

	.netease-player__track-title {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.25;
		color: rgb(var(--black));
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.netease-player__meta {
		margin: 0;
		font-size: 0.8rem;
		line-height: 1.3;
		color: rgb(var(--gray));
	}

	.netease-player__progress-row {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		gap: 0.55rem;
		align-items: center;
	}

	.netease-player__time {
		font-size: 0.72rem;
		font-variant-numeric: tabular-nums;
		color: rgb(var(--gray));
	}

	.netease-player__seek {
		width: 100%;
		height: 4px;
		margin: 0;
		accent-color: rgb(var(--accent-rgb));
	}

	.netease-player__controls {
		display: flex;
		align-items: center;
		flex-wrap: nowrap;
		gap: 0.34rem;
	}

	.netease-player__control {
		padding: 0.48rem 0.4rem;
	}

	.netease-player__control--circle {
		width: 2.02rem;
		height: 2.02rem;
		padding: 0;
		border-radius: 999px;
		flex: 0 0 auto;
	}

	.netease-player__control--primary {
		background: rgb(var(--black));
		color: rgb(var(--surface-rgb));
		border-color: rgba(var(--black), 0.08);
	}

	.netease-player__icon {
		width: 1.18rem;
		height: 1.18rem;
		flex: 0 0 auto;
	}

	.netease-player__icon--stroke {
		fill: none;
		stroke: currentColor;
		stroke-width: 1.9;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.netease-player__icon--fill {
		fill: currentColor;
		stroke: none;
	}

	.netease-player__icon-pause,
	.netease-player__mode-icon,
	.netease-player__mode-icon--loop,
	.netease-player__mode-icon--random {
		display: none;
	}

	.netease-player__control--primary[data-state='playing'] .netease-player__icon-play,
	.netease-player__control--primary[data-state='paused'] .netease-player__icon-pause {
		display: none;
	}

	.netease-player__control--primary[data-state='playing'] .netease-player__icon-pause,
	.netease-player__control--primary[data-state='paused'] .netease-player__icon-play {
		display: block;
	}

	.netease-player__mode[data-mode='sequence'] .netease-player__mode-icon--sequence,
	.netease-player__mode[data-mode='loop'] .netease-player__mode-icon--loop,
	.netease-player__mode[data-mode='random'] .netease-player__mode-icon--random {
		display: block;
	}

	.netease-player__queue {
		margin-top: 0.55rem;
		padding: 0.45rem;
		max-height: 12rem;
