---
import BaseHead from '../components/BaseHead.astro';
import FloatingActions from '../components/FloatingActions.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const basePath = import.meta.env.BASE_URL;
const backgroundImage = `${basePath}vocaloid/vocaloid-01.jpeg`;
const links = [
	{ href: `${basePath}blog/`, label: 'Blogs' },
	{ href: `${basePath}vocaloid/`, label: 'Vocaloid' },
	{ href: `${basePath}about/`, label: 'About' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description="Sa1varsan's Blog home page." />
	</head>
	<body>
		<Header />
		<main class="home-page">
			<section class="hero" style={`--hero-image: url('${backgroundImage}');`}>
				<div class="hero-inner">
					<h1>{SITE_TITLE}</h1>
					<p class="signature">Whatever is worth doing is worth doing well.</p>
					<nav class="hero-links" aria-label="Home quick links">
						{
							links.map((link) => (
								<a href={link.href} class="hero-link">{link.label}</a>
							))
						}
					</nav>
				</div>
			</section>
		</main>
		<FloatingActions />
	</body>
</html>

<style>
	:global(:root) {
		--home-hero-overlay-top: rgba(246, 248, 253, 0.08);
		--home-hero-overlay-mid: rgba(246, 248, 253, 0.24);
		--home-hero-overlay-bottom: rgba(246, 248, 253, 0.78);
		--home-hero-glow: rgba(255, 255, 255, 0.34);
		--home-panel-bg: rgba(var(--surface-rgb), 0.48);
		--home-panel-border: rgba(var(--black), 0.12);
		--home-panel-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
		--home-title-color: rgb(var(--black));
		--home-copy-color: rgba(var(--black), 0.78);
		--home-link-bg: rgba(var(--surface-rgb), 0.34);
		--home-link-border: rgba(var(--black), 0.15);
		--home-link-color: rgb(var(--black));
		--home-link-hover-bg: rgba(var(--surface-rgb), 0.52);
		--home-link-hover-border: rgba(var(--accent-rgb), 0.4);
	}

	:global(:root[data-theme='dark']) {
		--home-hero-overlay-top: rgba(7, 9, 14, 0.16);
		--home-hero-overlay-mid: rgba(7, 9, 14, 0.52);
		--home-hero-overlay-bottom: rgba(7, 9, 14, 0.84);
		--home-hero-glow: rgba(255, 255, 255, 0.2);
		--home-panel-bg: rgba(var(--surface-rgb), 0.34);
		--home-panel-border: rgba(255, 255, 255, 0.14);
		--home-panel-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
		--home-title-color: rgb(var(--black));
		--home-copy-color: rgba(var(--black), 0.86);
		--home-link-bg: rgba(var(--surface-rgb), 0.22);
		--home-link-border: rgba(255, 255, 255, 0.14);
		--home-link-color: rgb(var(--black));
		--home-link-hover-bg: rgba(var(--surface-rgb), 0.34);
		--home-link-hover-border: rgba(var(--accent-rgb), 0.45);
	}

	@media (prefers-color-scheme: dark) {
		:global(:root[data-theme='system']) {
			--home-hero-overlay-top: rgba(7, 9, 14, 0.16);
			--home-hero-overlay-mid: rgba(7, 9, 14, 0.52);
			--home-hero-overlay-bottom: rgba(7, 9, 14, 0.84);
			--home-hero-glow: rgba(255, 255, 255, 0.2);
			--home-panel-bg: rgba(var(--surface-rgb), 0.34);
			--home-panel-border: rgba(255, 255, 255, 0.14);
			--home-panel-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
			--home-title-color: rgb(var(--black));
			--home-copy-color: rgba(var(--black), 0.86);
			--home-link-bg: rgba(var(--surface-rgb), 0.22);
			--home-link-border: rgba(255, 255, 255, 0.14);
			--home-link-color: rgb(var(--black));
			--home-link-hover-bg: rgba(var(--surface-rgb), 0.34);
			--home-link-hover-border: rgba(var(--accent-rgb), 0.45);
		}
	}

	.home-page {
		width: 100vw;
		max-width: none;
		min-height: calc(100dvh - var(--site-header-height, 4.5rem));
		margin: 0;
		padding: 0;
	}

	.hero {
		position: relative;
		min-height: calc(100dvh - var(--site-header-height, 4.5rem));
		display: flex;
		align-items: flex-end;
		padding: 2rem;
		box-sizing: border-box;
		background-image: var(--hero-image);
		background-position: center;
		background-repeat: no-repeat;
		background-size: cover;
		isolation: isolate;
	}

	.hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(
				180deg,
				var(--home-hero-overlay-top) 0%,
				var(--home-hero-overlay-mid) 58%,
				var(--home-hero-overlay-bottom) 100%
			),
			radial-gradient(circle at 18% 18%, var(--home-hero-glow) 0%, rgba(255, 255, 255, 0) 34%);
		z-index: -1;
	}

	.hero-inner {
		max-width: min(720px, 100%);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.4rem 1.5rem;
		border: 1px solid var(--home-panel-border);
		background: var(--home-panel-bg);
		backdrop-filter: blur(12px);
		box-shadow: var(--home-panel-shadow);
	}

	.hero-inner h1 {
		margin: 0;
		font-size: clamp(2.5rem, 7vw, 4.8rem);
		line-height: 0.96;
		letter-spacing: -0.04em;
		color: var(--home-title-color);
	}

	.signature {
		margin: 0;
		font-size: 1rem;
		line-height: 1.55;
		color: var(--home-copy-color);
	}

	.hero-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.hero-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 8.5rem;
		padding: 0.9rem 1.25rem;
		border: 1px solid var(--home-link-border);
		background: var(--home-link-bg);
		color: var(--home-link-color);
		text-decoration: none;
		font-weight: 700;
		letter-spacing: 0.01em;
		transition:
			transform 0.18s ease,
			background 0.18s ease,
			border-color 0.18s ease;
	}

	.hero-link:hover {
		transform: translateY(-1px);
		background: var(--home-link-hover-bg);
		border-color: var(--home-link-hover-border);
		color: var(--home-link-color);
	}

	@media (max-width: 720px) {
		.hero {
			align-items: flex-end;
			padding: 1rem;
		}

		.hero-inner {
			padding: 1rem;
			gap: 0.8rem;
		}

		.signature {
			font-size: 0.92rem;
		}

		.hero-link {
			min-width: calc(50% - 0.4rem);
			flex: 1 1 calc(50% - 0.4rem);
		}
	}
</style>
